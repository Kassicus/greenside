# Unity project lives in the Greenside/ subfolder.
# Based on the official Unity .gitignore:
# https://github.com/github/gitignore/blob/main/Unity.gitignore

# --- Unity generated folders (cache, temp, logs, per-user) ---
/Greenside/[Ll]ibrary/
/Greenside/[Tt]emp/
/Greenside/[Oo]bj/
/Greenside/[Bb]uild/
/Greenside/[Bb]uilds/
/Greenside/[Ll]ogs/
/Greenside/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data.
/Greenside/[Mm]emoryCaptures/

# Recordings can get excessive in size.
/Greenside/[Rr]ecordings/

# Autogenerated Jetbrains Rider plugin
/Greenside/[Aa]ssets/Plugins/Editor/JetBrains*

# --- IDE / editor project files (auto-generated by Unity) ---
.vs/
.vscode/
.idea/
.gradle/
.consulo/
ExportedObj/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# --- Builds ---
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/Greenside/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/Greenside/[Aa]ssets/[Ss]treamingAssets/aa.meta
/Greenside/[Aa]ssets/[Ss]treamingAssets/aa/*

# --- OS / editor cruft ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
